graph TD
    subgraph UI["UI (React + Vite)"]
        REACT["React SPA<br/>ui/src/"]
        VITE["Vite dev server"]
    end

    subgraph Server["Server (Node.js)"]
        API["API Routes<br/>server/src/"]
        HEARTBEAT["Heartbeat Scheduler<br/>Agent wake/check cycles"]
        GOVERNANCE["Governance Engine<br/>Approvals, budgets, overrides"]
        TICKETS["Ticket System<br/>Task checkout, delegation"]
        DOCS["Document Service<br/>Issue documents + revisions"]
    end

    subgraph Plugins["Plugin System"]
        PLUGIN_REG["Plugin Registry<br/>Install, enable, configure"]
        PLUGIN_LOADER["Plugin Loader<br/>Manifest validation + loading"]
        PLUGIN_WORKER["Worker Manager<br/>Sandboxed plugin workers"]
        PLUGIN_SDK["Plugin SDK<br/>@paperclipai/plugin-sdk"]
        PLUGIN_EVENTS["Event Bus<br/>Plugin subscriptions"]
        PLUGIN_JOBS["Job Scheduler<br/>Cron + one-shot jobs"]
        PLUGIN_UI["UI Slots + Bridge<br/>Plugin panels in dashboard"]
    end

    subgraph Packages["Shared Packages"]
        DB["@paperclipai/db<br/>Drizzle ORM + migrations"]
        SHARED["@paperclipai/shared<br/>Types, utils, validators"]
        ADAPTERS["@paperclipai/adapters<br/>Agent runtime adapters"]
        ADAPTER_UTILS["@paperclipai/adapter-utils<br/>Shared adapter helpers"]
    end

    subgraph Storage["Data Layer"]
        PG["PostgreSQL<br/>(embedded or external)"]
    end

    subgraph Agents["External Agents"]
        OPENCLAW["OpenClaw"]
        CLAUDE["Claude Code"]
        CODEX["Codex"]
        CURSOR["Cursor"]
        BASH["Bash scripts"]
        HTTP["HTTP endpoints"]
    end

    subgraph CLI["CLI"]
        CLIPCLI["cli/<br/>paperclipai CLI<br/>(onboard, manage)"]
    end

    REACT --> API
    REACT --> PLUGIN_UI
    API --> DB
    API --> HEARTBEAT
    API --> GOVERNANCE
    API --> TICKETS
    API --> DOCS
    API --> PLUGIN_REG
    DB --> PG
    HEARTBEAT --> ADAPTERS
    ADAPTERS --> ADAPTER_UTILS
    ADAPTERS --> OPENCLAW
    ADAPTERS --> CLAUDE
    ADAPTERS --> CODEX
    ADAPTERS --> CURSOR
    ADAPTERS --> BASH
    ADAPTERS --> HTTP
    TICKETS --> SHARED
    DOCS --> DB
    CLIPCLI --> API
    PLUGIN_REG --> PLUGIN_LOADER
    PLUGIN_LOADER --> PLUGIN_WORKER
    PLUGIN_WORKER --> PLUGIN_SDK
    PLUGIN_WORKER --> PLUGIN_EVENTS
    PLUGIN_EVENTS --> PLUGIN_JOBS
    PLUGIN_UI --> PLUGIN_WORKER

